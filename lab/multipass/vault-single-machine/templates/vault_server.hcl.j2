ui = true

storage "file" {
  path = "{{ vault_data_dir }}"
}

listener "tcp" {
  address     = "{{ ansible_facts["default_ipv4"]["address"] }}:8200"
  tls_disable = 1
}

api_addr     = "http://{{ ansible_facts["default_ipv4"]["address"] }}:8200"
cluster_addr = "http://{{ ansible_facts["default_ipv4"]["address"] }}:8201"
