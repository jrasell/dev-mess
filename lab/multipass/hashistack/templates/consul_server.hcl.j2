datacenter = "lcy1"
data_dir   = "{{ consul_data_dir }}"
node_name  = "{{ inventory_hostname }}"

server           = true
bootstrap_expect = {{ groups['hashi_ctrl'] | length }}

ui_config {
  enabled = true
}

bind_addr   = "{{ ansible_facts['default_ipv4']['address'] }}"
client_addr = "{{ ansible_facts['default_ipv4']['address'] }}"

addresses {
  http  = "{{ ansible_facts['default_ipv4']['address'] }}"
  https = "{{ ansible_facts['default_ipv4']['address'] }}"
  grpc  = "{{ ansible_facts['default_ipv4']['address'] }}"
}

ports {
  http     = -1
  https    = 8501
  grpc     = -1
  grpc_tls = 8503
}

retry_join = [
  {% for host in groups['hashi_ctrl'] %}
  "{{ hostvars[host]['ansible_facts']['default_ipv4']['address'] }}"{{ "," if not loop.last else "" }}
  {% endfor %}
]

acl {
  enabled                  = true
  default_policy           = "deny"
  enable_token_persistence = true
}
