{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "icon_theme": "Catppuccin Latte",
  "edit_predictions": {
    "provider": "copilot",
    "disabled_globs": [],
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "default_profile": "write",
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-opus-4.6",
    },
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "buffer_font_size": 15,
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": false,
    "show_parameter_hints": false,
  },
  "lsp": {
    "gopls": {
      "initialization_options": {
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "ignoredError": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark",
  },
  "ui_font_size": 16,
  "wrap_guides": [80, 100],
}
